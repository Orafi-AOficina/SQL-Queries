## Ignore Visual Studio SSDT sqlproj specific temporary files, build results, etc
## 
##
## Get latest from https://github.com/github/gitignore/blob/master/SSDT-sqlproj.gitignore
# Build output
bin/
obj/

# DACPAC files
*.dacpac

# Publish profiles (optional, if environment-specific)
*.publish.xml

# SQL Server debug files
*.dbmdl
*.sqlcmdvars

# Visual Studio settings
.vs/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Backup files
*.bak
*.log

# DBeaver - SEMPRE ignorar
.dbeaver/

# OU se quiser controle granular (para projetos compartilhados):
.dbeaver/data-source/
.dbeaver/general_cache/
.dbeaver/.metadata/
.dbeaver/.metadata/.plugins/
.dbeaver/.metadata/.mylyn/
.dbeaver/.metadata/.plugins/org.eclipse.core.resources/
.dbeaver/data-source.cache/

# Arquivos de workspace
.metadata/
.settings/
.project
.classpath

# Logs e cache
*.log
*.tmp
cache/
temp/

# Senhas e segurança (CRÍTICO)
*.kdbx
credentials/
.vscode/mssql_settings.json
.env
.env.local

# Python / uv
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/